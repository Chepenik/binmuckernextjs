NVIDIA_API_KEY=your-nvidia-api-key-here

# Google Places API (New). Used by /api/audit to pull real Google Business
# Profile data (rating, review count, categories, photos) for the business
# being audited. Optional — the audit still runs without it, just with less
# accuracy. Get a key at https://console.cloud.google.com/ → APIs → Places API.
GOOGLE_PLACES_API_KEY=

# Upstash Redis (via Vercel Marketplace) for persistent rate limiting.
# The Marketplace integration sets these automatically. KV_* names are
# the legacy Vercel KV variables; UPSTASH_* are the current names — either works.
KV_REST_API_URL=
KV_REST_API_TOKEN=
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
